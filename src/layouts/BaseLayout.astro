---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  schema?: object;
}

const {
  title,
  description = "Academic Halt - Free Notes, Solutions, Papers & Study Material for JEE, NEET, CBSE, UPSC, GATE and all major exams.",
  canonical,
  ogType = "website",
  schema
} = Astro.props;

const siteUrl = "https://www.academichalt.in";
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Academic Halt</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={`${title} | Academic Halt`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Academic Halt" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Academic Halt`} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">
  <Header />
  <main class="flex-1"><slot /></main>
  <Footer />
</body>
</html>
