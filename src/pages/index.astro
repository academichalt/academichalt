---
import BaseLayout from '../layouts/BaseLayout.astro';
import ResourceCard from '../components/ResourceCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getCollection } from 'astro:content';

const allResources = await getCollection('resources');
const resources = allResources.map(r => ({ ...r.data, slug: r.id }));

const categoryMap: Record<string, number> = {};
resources.forEach(r => { categoryMap[r.category] = (categoryMap[r.category] || 0) + 1; });
const categories = Object.entries(categoryMap).sort((a, b) => b[1] - a[1]);

const examMap: Record<string, number> = {};
resources.forEach(r => { examMap[r.exam] = (examMap[r.exam] || 0) + 1; });
const exams = Object.entries(examMap).sort((a, b) => b[1] - a[1]);

const typeMap: Record<string, number> = {};
resources.forEach(r => { typeMap[r.resourceType] = (typeMap[r.resourceType] || 0) + 1; });
const resourceTypes = Object.entries(typeMap).sort((a, b) => b[1] - a[1]);

const tagMap: Record<string, number> = {};
resources.forEach(r => { r.tags.forEach((t: string) => { tagMap[t] = (tagMap[t] || 0) + 1; }); });
const tags = Object.entries(tagMap).sort((a, b) => b[1] - a[1]).slice(0, 32);

const searchResources = resources.map(r => ({ title: r.title, slug: r.slug, category: r.category, exam: r.exam, resourceType: r.resourceType, tags: r.tags, source: r.source }));

const categoryMeta: Record<string, { color: string; icon: string }> = {
  "Physics": { color: "from-blue-500 to-blue-600", icon: "⚡" },
  "Chemistry": { color: "from-green-500 to-green-600", icon: "🧪" },
  "Mathematics": { color: "from-purple-500 to-purple-600", icon: "📐" },
  "Biology": { color: "from-emerald-500 to-emerald-600", icon: "🧬" },
  "General Studies": { color: "from-yellow-500 to-yellow-600", icon: "🌏" },
  "Computer Science": { color: "from-cyan-500 to-cyan-600", icon: "💻" },
  "English": { color: "from-pink-500 to-pink-600", icon: "✍️" },
  "History": { color: "from-amber-500 to-amber-600", icon: "🏛️" },
};

const examMeta: Record<string, { color: string; icon: string }> = {
  "JEE Main": { color: "from-orange-500 to-orange-600", icon: "🎯" },
  "JEE Advanced": { color: "from-red-500 to-red-600", icon: "🏆" },
  "NEET": { color: "from-teal-500 to-teal-600", icon: "🩺" },
  "CBSE Class 12": { color: "from-indigo-500 to-indigo-600", icon: "📗" },
  "CBSE Class 10": { color: "from-blue-400 to-blue-500", icon: "📘" },
  "UPSC CSE": { color: "from-yellow-600 to-amber-600", icon: "🏛️" },
  "GATE": { color: "from-cyan-500 to-cyan-600", icon: "⚙️" },
  "Class 11": { color: "from-violet-500 to-violet-600", icon: "📙" },
};
---
<BaseLayout title="Free Notes, Solutions & Papers for JEE, NEET, CBSE & More" description="Download free notes, solutions, previous year papers and sample papers for JEE Main, JEE Advanced, NEET, CBSE, UPSC, GATE and all major exams. Academic Halt.">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white py-16 sm:py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-32 h-32 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-48 h-48 bg-accent-400 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur border border-white/20 rounded-full px-4 py-1.5 text-sm font-medium mb-6">
          <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse"></span>
          {resources.length}+ Resources Available Free
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl leading-tight mb-6">
          Notes, Solutions &<br class="hidden sm:block" />
          <span class="text-accent-400">Papers for Every Exam</span>
        </h1>
        <p class="text-lg sm:text-xl text-primary-200 mb-10 leading-relaxed">
          Free study material for JEE, NEET, CBSE, UPSC, GATE and more. Handwritten notes, NCERT solutions, previous year papers, and sample papers — all in one place.
        </p>
        <SearchBar resources={searchResources} />
        <div class="grid grid-cols-3 gap-6 mt-12 max-w-lg mx-auto">
          <div class="text-center">
            <div class="font-display font-bold text-3xl text-white">{resources.length}+</div>
            <div class="text-primary-300 text-sm">Resources</div>
          </div>
          <div class="text-center border-x border-white/20">
            <div class="font-display font-bold text-3xl text-white">{exams.length}</div>
            <div class="text-primary-300 text-sm">Exams</div>
          </div>
          <div class="text-center">
            <div class="font-display font-bold text-3xl text-white">{categories.length}</div>
            <div class="text-primary-300 text-sm">Subjects</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Resource Type Pills -->
  <section class="bg-white border-b border-gray-100 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap gap-2 justify-center">
        {resourceTypes.map(([type, count]) => {
          const icons: Record<string,string> = { "Notes": "📝", "Solutions": "✅", "Previous Year Papers": "📄", "Sample Papers": "📋", "Question Bank": "❓" };
          return (
            <a href={`/type/${type.toLowerCase().replace(/ /g, '-')}`} class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-50 hover:bg-primary-50 border border-gray-200 hover:border-primary-300 rounded-full text-sm font-medium text-gray-700 hover:text-primary-700 transition-all">
              <span>{icons[type] || '📚'}</span> {type} <span class="text-gray-400 text-xs">({count})</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Resources Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" id="resources">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-gray-900">All Resources</h2>
        <p class="text-gray-500 mt-1">{resources.length} resources available</p>
      </div>
      <a href="/resources" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">View All →</a>
    </div>
    <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
      <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium bg-primary-600 text-white" data-cat="all">All</button>
      {categories.map(([cat]) => (
        <button class="filter-btn px-4 py-2 rounded-lg text-sm font-medium bg-white text-gray-600 border border-gray-200 hover:border-primary-300 hover:text-primary-700 transition-colors" data-cat={cat}>{cat}</button>
      ))}
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="resources-grid">
      {resources.map(r => (
        <div class="resource-item" data-cat={r.category}>
          <ResourceCard title={r.title} slug={r.slug} description={r.description} category={r.category} exam={r.exam} resourceType={r.resourceType} tags={r.tags} source={r.source} year={r.year} />
        </div>
      ))}
    </div>
  </section>

  <!-- Browse by Exam -->
  <section class="bg-gray-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-gray-900 mb-2">Browse by Exam</h2>
        <p class="text-gray-500">Find resources organized by your target exam</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {exams.map(([exam, count]) => {
          const meta = examMeta[exam] || { color: "from-gray-500 to-gray-600", icon: "📚" };
          return (
            <a href={`/exam/${exam.toLowerCase().replace(/ /g, '-')}`} class="group bg-white rounded-xl p-5 text-center border border-gray-200 hover:border-primary-300 hover:shadow-md transition-all duration-200">
              <div class={`w-12 h-12 bg-gradient-to-br ${meta.color} rounded-xl flex items-center justify-center text-2xl mx-auto mb-3 group-hover:scale-110 transition-transform`}>{meta.icon}</div>
              <h3 class="font-display font-semibold text-sm text-gray-900 mb-1">{exam}</h3>
              <p class="text-xs text-gray-500">{count} resources</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Browse by Subject -->
  <section class="py-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-gray-900 mb-2">Browse by Subject</h2>
      <p class="text-gray-500">Find notes and papers organized by subject</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {categories.map(([cat, count]) => {
        const meta = categoryMeta[cat] || { color: "from-gray-500 to-gray-600", icon: "📚" };
        return (
          <a href={`/category/${cat.toLowerCase().replace(/ /g, '-')}`} class="group bg-white rounded-xl p-5 text-center border border-gray-200 hover:border-primary-300 hover:shadow-md transition-all duration-200">
            <div class={`w-12 h-12 bg-gradient-to-br ${meta.color} rounded-xl flex items-center justify-center text-2xl mx-auto mb-3 group-hover:scale-110 transition-transform`}>{meta.icon}</div>
            <h3 class="font-display font-semibold text-sm text-gray-900 mb-1">{cat}</h3>
            <p class="text-xs text-gray-500">{count} resources</p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Tags -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-gray-900 mb-2">Browse by Topic</h2>
        <p class="text-gray-500">Find resources for specific topics you want to study</p>
      </div>
      <div class="flex flex-wrap gap-3 justify-center">
        {tags.map(([tag, count]) => (
          <a href={`/tag/${tag.toLowerCase().replace(/ /g, '-')}`} class="px-4 py-2 bg-white border border-gray-200 text-gray-700 rounded-full text-sm font-medium hover:border-primary-400 hover:text-primary-700 hover:bg-primary-50 transition-all duration-150">
            {tag} <span class="text-gray-400 text-xs ml-1">({count})</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sources/Institutes -->
  <section class="bg-gray-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-2">Top Sources</h2>
        <p class="text-gray-400">Material from India's best coaching institutes and official boards</p>
      </div>
      <div class="flex flex-wrap gap-4 justify-center">
        {[...new Set(resources.map(r => r.source))].map(src => (
          <span class="flex items-center gap-2 px-5 py-3 bg-white/5 border border-white/10 rounded-xl text-white font-medium text-sm">
            📄 {src}
          </span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const resourceItems = document.querySelectorAll('.resource-item');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-cat');
      filterBtns.forEach(b => { b.classList.remove('bg-primary-600','text-white'); b.classList.add('bg-white','text-gray-600','border','border-gray-200'); });
      btn.classList.add('bg-primary-600','text-white');
      btn.classList.remove('bg-white','text-gray-600','border','border-gray-200');
      resourceItems.forEach(item => {
        (item as HTMLElement).style.display = (cat === 'all' || item.getAttribute('data-cat') === cat) ? '' : 'none';
      });
    });
  });
</script>
