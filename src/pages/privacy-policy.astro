---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy" description="Academic Halt Privacy Policy — how we collect, use, and protect your data.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">Privacy Policy</span></nav>
    <div class="bg-white rounded-2xl border border-gray-200 p-8 sm:p-12">
      <h1 class="font-display font-bold text-3xl text-gray-900 mb-6">Privacy Policy</h1>
      <div class="space-y-4 text-gray-700">
        <p>This Privacy Policy describes how Academic Halt collects, uses, and shares information about you when you use our website at academichalt.in.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Information We Collect</h2>
        <p>We may collect usage data such as pages visited, time spent, and browser type through analytics tools. We do not collect personally identifiable information unless you voluntarily submit it through our contact form.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Cookies</h2>
        <p>We use cookies to improve your browsing experience. You can disable cookies in your browser settings.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Contact</h2>
        <p>For privacy-related questions, email us at <a href="mailto:contact@academichalt.in" class="text-primary-600 hover:underline">contact@academichalt.in</a>.</p>
        <p class="text-sm text-gray-400 pt-4">Last updated: January 2026</p>
      </div>
    </div>
  </div>
</BaseLayout>
