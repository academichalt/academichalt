---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allResources = await getCollection('resources');
const tagMap: Record<string, number> = {};
allResources.forEach(r => { r.data.tags.forEach((t: string) => { tagMap[t] = (tagMap[t] || 0) + 1; }); });
const tags = Object.entries(tagMap).sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="All Topics & Tags" description="Browse free study resources by topic — Mechanics, Organic Chemistry, Calculus, Genetics, Indian History and more.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">Topics</span></nav>
    <h1 class="font-display font-bold text-3xl text-gray-900 mb-2">All Topics & Tags</h1>
    <p class="text-gray-500 mb-10">{tags.length} topics · Find resources by specific topics</p>
    <div class="flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a href={`/tag/${tag.toLowerCase().replace(/ /g, '-')}`} class="group flex items-center gap-2 px-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm font-medium hover:border-primary-400 hover:bg-primary-50 hover:text-primary-700 transition-all duration-150">
          <span class="text-gray-900 group-hover:text-primary-700">{tag}</span>
          <span class="text-xs px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full group-hover:bg-primary-100 group-hover:text-primary-600">{count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
