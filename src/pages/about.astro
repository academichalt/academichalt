---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allResources = await getCollection('resources');
---
<BaseLayout title="About Us" description="Academic Halt is your free destination for notes, solutions, papers and study material for every exam in India.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">About Us</span></nav>
    <div class="bg-white rounded-2xl border border-gray-200 p-8 sm:p-12">
      <h1 class="font-display font-bold text-3xl sm:text-4xl text-gray-900 mb-6">About Academic Halt</h1>
      <div class="space-y-5 text-gray-700">
        <p class="text-lg leading-relaxed"><strong>Academic Halt</strong> is a free educational resource platform dedicated to helping students across India access quality study material — notes, solutions, previous year papers, and sample papers — without any financial barrier.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Our Mission</h2>
        <p>We believe every student in India — whether from a metro city or a small town — deserves access to the same quality study resources. Our mission is to build a centralized, freely accessible repository of the best notes, solutions, and papers for every major exam.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">What We Offer</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>{allResources.length}+ free resources including notes, solutions, PYQs, and sample papers</li>
          <li>Material for JEE Main, JEE Advanced, NEET, CBSE (Class 10 & 12), UPSC, GATE and more</li>
          <li>Resources organized by subject, exam, type, and topic for easy discovery</li>
          <li>Content sourced from top institutes: NCERT, Allen, FIITJEE, Vision IAS, Made Easy and more</li>
          <li>Regular updates with new resources and papers as exams happen</li>
          <li>Active community on Telegram, Instagram, and YouTube</li>
        </ul>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4">
          <div class="bg-primary-50 rounded-xl p-5 text-center">
            <div class="font-display font-bold text-3xl text-primary-700">{allResources.length}+</div>
            <div class="text-sm text-gray-600 mt-1">Resources Available</div>
          </div>
          <div class="bg-orange-50 rounded-xl p-5 text-center">
            <div class="font-display font-bold text-3xl text-orange-600">10K+</div>
            <div class="text-sm text-gray-600 mt-1">Students Helped</div>
          </div>
          <div class="bg-green-50 rounded-xl p-5 text-center">
            <div class="font-display font-bold text-3xl text-green-700">Free</div>
            <div class="text-sm text-gray-600 mt-1">Always & Forever</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
