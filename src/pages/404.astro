---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found">
  <div class="max-w-2xl mx-auto px-4 py-32 text-center">
    <div class="text-8xl mb-6">📄</div>
    <h1 class="font-display font-bold text-4xl text-gray-900 mb-4">Page Not Found</h1>
    <p class="text-gray-500 mb-8">Looks like this resource doesn't exist — or has been moved. Try searching for what you need.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/" class="px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-colors">Go Home</a>
      <a href="/resources" class="px-6 py-3 bg-white border border-gray-200 hover:border-primary-300 text-gray-700 font-semibold rounded-xl transition-colors">Browse Resources</a>
    </div>
  </div>
</BaseLayout>
