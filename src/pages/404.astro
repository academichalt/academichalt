---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 – Page Not Found">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <div class="text-8xl mb-6 animate-bounce-slow">📚</div>
    <h1 class="font-display font-extrabold text-6xl text-white mb-4">404</h1>
    <h2 class="section-title mb-4 text-orange-400">Page Not Found</h2>
    <p class="text-slate-400 mb-8 leading-relaxed">
      The page you're looking for doesn't exist or may have been moved.<br />
      Let's get you back to studying!
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/" class="btn-primary">
        ← Back to Home
      </a>
      <a href="/books" class="btn-secondary">
        Browse All Books
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .animate-bounce-slow { animation: bounceSlow 2s ease-in-out infinite; }
</style>
