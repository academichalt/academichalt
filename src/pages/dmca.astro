---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="DMCA" description="Academic Halt DMCA Policy — report copyright infringement.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">DMCA</span></nav>
    <div class="bg-white rounded-2xl border border-gray-200 p-8 sm:p-12">
      <h1 class="font-display font-bold text-3xl text-gray-900 mb-6">DMCA Policy</h1>
      <div class="space-y-4 text-gray-700">
        <p>Academic Halt respects intellectual property rights and complies with the Digital Millennium Copyright Act (DMCA).</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Copyright Notice</h2>
        <p>We do not host any copyrighted PDF files on our servers. All download links point to third-party hosting services.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Filing a DMCA Complaint</h2>
        <p>If you are a copyright owner and believe that content on our website infringes your copyright, please send a notice to <a href="mailto:dmca@academichalt.in" class="text-primary-600 hover:underline">dmca@academichalt.in</a> with:</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>Your contact information</li>
          <li>Description of the copyrighted work</li>
          <li>URL of the infringing content</li>
          <li>A statement that you are the copyright owner</li>
        </ul>
        <p>We will respond within 48 hours and remove the relevant links if necessary.</p>
        <p class="text-sm text-gray-400 pt-4">Last updated: January 2026</p>
      </div>
    </div>
  </div>
</BaseLayout>
