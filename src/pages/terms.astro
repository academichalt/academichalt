---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Terms & Conditions" description="Academic Halt Terms and Conditions of use.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">Terms & Conditions</span></nav>
    <div class="bg-white rounded-2xl border border-gray-200 p-8 sm:p-12">
      <h1 class="font-display font-bold text-3xl text-gray-900 mb-6">Terms & Conditions</h1>
      <div class="space-y-4 text-gray-700">
        <p>By accessing Academic Halt at academichalt.in, you agree to be bound by these terms and conditions.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Use of Website</h2>
        <p>This website is provided for educational purposes only. You agree not to misuse this website or use it for any illegal purpose.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Intellectual Property</h2>
        <p>The content on this website, including text, graphics, and design, is the property of Academic Halt. Book PDFs linked from this site remain the property of their respective authors and publishers.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Limitation of Liability</h2>
        <p>Academic Halt shall not be liable for any damages arising from the use or inability to use this website or its resources.</p>
        <p class="text-sm text-gray-400 pt-4">Last updated: January 2026</p>
      </div>
    </div>
  </div>
</BaseLayout>
