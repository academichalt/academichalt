---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Disclaimer" description="Academic Halt disclaimer — we do not host copyrighted files. All content is for educational purposes only.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">Disclaimer</span></nav>
    <div class="bg-white rounded-2xl border border-gray-200 p-8 sm:p-12">
      <h1 class="font-display font-bold text-3xl text-gray-900 mb-6">Disclaimer</h1>
      <div class="space-y-4 text-gray-700">
        <p>Academic Halt (academichalt.in) is an educational resource website. We do not host, upload, or store any copyrighted PDF files on our servers.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">External Links</h2>
        <p>All download links on Academic Halt point to third-party file hosting services. We are not responsible for the content hosted on external servers. If you find any copyrighted material linked from our website, please <a href="/contact" class="text-primary-600 hover:underline">contact us</a> immediately.</p>
        <h2 class="font-display font-bold text-xl text-gray-900 pt-2">Educational Purpose</h2>
        <p>All content on this website is provided for educational and informational purposes only. We encourage students to purchase original books and support authors and publishers.</p>
        <p class="text-sm text-gray-400 pt-4">Last updated: January 2026</p>
      </div>
    </div>
  </div>
</BaseLayout>
