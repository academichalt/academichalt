---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import { getCollection } from 'astro:content';

const allResources = await getCollection('resources');
const resources = allResources.map(r => ({ ...r.data, slug: r.id }));
---
<BaseLayout title="All Resources" description={`Browse all ${resources.length} free study resources — notes, solutions, papers for JEE, NEET, CBSE, UPSC and more.`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">All Resources</span></nav>
    <h1 class="font-display font-bold text-3xl text-gray-900 mb-2">All Resources</h1>
    <p class="text-gray-500 mb-8">{resources.length} resources available for free download</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {resources.map(r => (
        <ResourceCard title={r.title} slug={r.slug} description={r.description} category={r.category} exam={r.exam} resourceType={r.resourceType} tags={r.tags} source={r.source} year={r.year} />
      ))}
    </div>
  </div>
</BaseLayout>
