---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Us" description="Get in touch with Academic Halt. Report DMCA issues, request books, or connect with us on social media.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> › <span class="text-gray-900">Contact</span></nav>
    <h1 class="font-display font-bold text-3xl sm:text-4xl text-gray-900 mb-8">Contact Us</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4">
        <a href="mailto:contact@academichalt.in" class="flex items-center gap-4 bg-white rounded-xl border border-gray-200 p-5 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center text-2xl">✉️</div>
          <div><div class="font-semibold text-gray-900">Email</div><div class="text-sm text-primary-600">contact@academichalt.in</div></div>
        </a>
        <a href="https://t.me/academichalt" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 bg-white rounded-xl border border-gray-200 p-5 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-2xl">📱</div>
          <div><div class="font-semibold text-gray-900">Telegram</div><div class="text-sm text-blue-600">@academichalt</div></div>
        </a>
        <a href="https://instagram.com/academichalt" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 bg-white rounded-xl border border-gray-200 p-5 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-pink-100 rounded-xl flex items-center justify-center text-2xl">📷</div>
          <div><div class="font-semibold text-gray-900">Instagram</div><div class="text-sm text-pink-600">@academichalt</div></div>
        </a>
        <a href="https://youtube.com/@academichalt" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 bg-white rounded-xl border border-gray-200 p-5 hover:border-primary-300 hover:shadow-md transition-all">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center text-2xl">▶️</div>
          <div><div class="font-semibold text-gray-900">YouTube</div><div class="text-sm text-red-600">@academichalt</div></div>
        </a>
      </div>
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="font-display font-semibold text-xl text-gray-900 mb-4">Send a Message</h2>
        <form class="space-y-4" action="https://formspree.io/f/academichalt" method="POST">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
            <input type="text" name="name" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm" placeholder="Rahul Sharma" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
            <input type="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm" placeholder="rahul@example.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
            <select name="subject" class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm">
              <option>General Query</option>
              <option>Book Request</option>
              <option>DMCA / Copyright</option>
              <option>Partnership</option>
              <option>Bug Report</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
            <textarea name="message" rows="4" required class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary-500 text-sm resize-none" placeholder="Your message..."></textarea>
          </div>
          <button type="submit" class="w-full py-3 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-lg transition-colors">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>
