---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="Contact Us – JEE Halt"
  description="Contact JEE Halt for book requests, suggestions, broken links, DMCA notices, or general enquiries."
  canonical="/contact"
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />

    <div class="mt-6">
      <h1 class="section-title mb-2">Contact Us</h1>
      <p class="text-slate-400 text-sm mb-8">
        Have a question, book request, or want to report an issue? Fill out the form below.
      </p>

      <div class="card p-6 sm:p-8">
        <form id="contact-form" class="space-y-5" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="form-group">
              <label class="form-label" for="name">Full Name *</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Email Address *</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="subject">Subject *</label>
            <select id="subject" name="subject" class="form-input" required>
              <option value="">Select a subject</option>
              <option value="book-request">Book Request</option>
              <option value="broken-link">Broken Link</option>
              <option value="dmca">DMCA / Copyright</option>
              <option value="suggestion">Suggestion</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="message">Message *</label>
            <textarea id="message" name="message" rows="5" class="form-input" placeholder="Your message…" required></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center" id="submit-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Send Message
          </button>

          <div id="form-success" class="hidden text-center p-4 bg-green-500/10 border border-green-500/25 rounded-lg">
            <p class="text-green-400 text-sm font-medium">✅ Message sent! We'll get back to you soon.</p>
          </div>
          <div id="form-error" class="hidden text-center p-4 bg-red-500/10 border border-red-500/25 rounded-lg">
            <p class="text-red-400 text-sm font-medium">❌ Please fill in all required fields.</p>
          </div>
        </form>
      </div>

      <!-- Quick Contact -->
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { icon: '📧', label: 'Email', value: 'contact@jeehalt.in', href: 'mailto:contact@jeehalt.in' },
          { icon: '💬', label: 'Telegram', value: '@jeehalt', href: 'https://t.me/jeehalt' },
          { icon: '📸', label: 'Instagram', value: '@jeehalt', href: 'https://instagram.com/jeehalt' },
        ].map(c => (
          <a href={c.href} class="card p-4 text-center group" target={c.href.startsWith('http') ? '_blank' : undefined} rel={c.href.startsWith('http') ? 'noopener' : undefined}>
            <div class="text-2xl mb-2">{c.icon}</div>
            <div class="text-xs text-slate-500 mb-1">{c.label}</div>
            <div class="text-sm font-medium text-slate-300 group-hover:text-orange-400 transition-colors">{c.value}</div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('email') as HTMLInputElement)?.value.trim();
    const subject = (document.getElementById('subject') as HTMLSelectElement)?.value;
    const message = (document.getElementById('message') as HTMLTextAreaElement)?.value.trim();

    const errorEl = document.getElementById('form-error');
    const successEl = document.getElementById('form-success');

    if (!name || !email || !subject || !message) {
      errorEl?.classList.remove('hidden');
      successEl?.classList.add('hidden');
      return;
    }

    errorEl?.classList.add('hidden');
    successEl?.classList.remove('hidden');
    (e.target as HTMLFormElement).reset();
  });
</script>

<style>
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-label { font-size: 0.8rem; font-weight: 500; color: #94a3b8; }
  .form-input {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
    color: #e2e8f0;
    font-size: 0.875rem;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    resize: vertical;
  }
  .form-input::placeholder { color: #475569; }
  .form-input:focus { border-color: rgba(249,115,22,0.5); background: rgba(255,255,255,0.06); }
  .form-input option { background: #1e293b; }
</style>
