---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const allBooks = await getCollection('books');
  const allTags = [...new Set(allBooks.flatMap(b => b.data.tags))];
  
  return allTags.map(tag => ({
    params: { tag },
    props: {
      books: allBooks.filter(b => b.data.tags.includes(tag)),
      tag,
    },
  }));
}

const { books, tag } = Astro.props;
const sorted = books.sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout
  title={`${tag} Books – Free PDF Download`}
  description={`Free ${tag} books and study material for JEE Main, JEE Advanced, NEET and CBSE. ${books.length} books available.`}
  canonical={`/tag/${encodeURIComponent(tag)}`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Tags', href: '/tags' },
      { label: tag },
    ]} />

    <div class="mt-4 mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">🏷️</span>
        <h1 class="section-title">{tag}</h1>
      </div>
      <p class="text-slate-400 text-sm">{books.length} books tagged with "{tag}"</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      {sorted.map(book => (
        <BookCard
          slug={book.slug}
          title={book.data.title}
          description={book.data.description}
          category={book.data.category}
          tags={book.data.tags}
          author={book.data.author}
          publisher={book.data.publisher}
          pages={book.data.pages}
          format={book.data.format}
        />
      ))}
    </div>
  </div>
</BaseLayout>
