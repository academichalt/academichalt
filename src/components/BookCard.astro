---
interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  tags: string[];
  author: string;
  publisher: string;
  pages: number;
  format: string;
}

const { slug, title, description, category, tags, author, publisher, pages, format } = Astro.props;
const shortDesc = description.length > 130 ? description.slice(0, 130) + '…' : description;
---

<article class="book-card card h-full flex flex-col">
  <div class="p-5 flex flex-col flex-1">
    <!-- Category + Format row -->
    <div class="flex items-center justify-between mb-3">
      <a href={`/category/${encodeURIComponent(category)}`} class="category-badge">{category}</a>
      <span class="text-xs text-slate-500 font-mono bg-slate-800/60 px-2 py-1 rounded">{format}</span>
    </div>

    <!-- Title -->
    <h3 class="book-title mb-2">
      <a href={`/book/${slug}`} class="hover:text-orange-400 transition-colors duration-200">
        {title}
      </a>
    </h3>

    <!-- Author -->
    <p class="text-xs text-slate-500 mb-3 flex items-center gap-1">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      {author} · {publisher}
    </p>

    <!-- Description -->
    <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">{shortDesc}</p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 4).map(tag => (
        <a href={`/tag/${encodeURIComponent(tag)}`} class="tag-chip">{tag}</a>
      ))}
      {tags.length > 4 && <span class="tag-chip opacity-60">+{tags.length - 4}</span>}
    </div>

    <!-- Footer row -->
    <div class="flex items-center justify-between pt-4 border-t border-white/5">
      <span class="text-xs text-slate-500 flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        {pages} pages
      </span>
      <a href={`/book/${slug}`} class="btn-primary text-xs py-1.5 px-3">
        View Details
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .book-card {
    height: 100%;
  }

  .book-title {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.4;
    color: #e2e8f0;
  }
</style>
