---
interface Props {
  title: string;
  slug: string;
  description: string;
  category: string;
  exam: string;
  resourceType: string;
  tags: string[];
  source: string;
  year?: number;
}
const { title, slug, description, category, exam, resourceType, tags, source, year } = Astro.props;

const typeColors: Record<string, string> = {
  "Notes": "bg-blue-100 text-blue-700",
  "Solutions": "bg-green-100 text-green-700",
  "Previous Year Papers": "bg-orange-100 text-orange-700",
  "Sample Papers": "bg-purple-100 text-purple-700",
  "Question Bank": "bg-pink-100 text-pink-700",
};
const typeIcons: Record<string, string> = {
  "Notes": "📝",
  "Solutions": "✅",
  "Previous Year Papers": "📄",
  "Sample Papers": "📋",
  "Question Bank": "❓",
};
const colorClass = typeColors[resourceType] || "bg-gray-100 text-gray-700";
const icon = typeIcons[resourceType] || "📚";
---
<article class="bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-lg transition-all duration-200 flex flex-col group">
  <div class="p-5 flex-1 flex flex-col">
    <div class="flex items-center gap-2 mb-3">
      <span class={`inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-1 rounded-full ${colorClass}`}>
        {icon} {resourceType}
      </span>
    </div>
    <h3 class="font-display font-semibold text-gray-900 text-base leading-snug mb-1 group-hover:text-primary-700 transition-colors line-clamp-2">{title}</h3>
    <p class="text-xs text-gray-500 mb-3">{source} · {exam}{year ? ` · ${year}` : ''}</p>
    <p class="text-sm text-gray-600 leading-relaxed flex-1 line-clamp-3 mb-4">{description}</p>
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 4).map(tag => (
        <a href={`/tag/${tag.toLowerCase().replace(/ /g, '-')}`} class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded hover:bg-primary-100 hover:text-primary-700 transition-colors">
          {tag}
        </a>
      ))}
    </div>
    <a href={`/resource/${slug}`} class="w-full text-center px-4 py-2.5 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold rounded-lg transition-colors duration-150">
      View & Download →
    </a>
  </div>
</article>
