---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.label,
    ...(crumb.href && { "item": `https://www.jeehalt.in${crumb.href}` })
  }))
};
---

<nav class="breadcrumb-nav" aria-label="Breadcrumb">
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <ol class="flex items-center flex-wrap gap-1 text-sm">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <svg class="w-3.5 h-3.5 text-slate-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>}
        {crumb.href ? (
          <a href={crumb.href} class="text-slate-400 hover:text-orange-400 transition-colors">{crumb.label}</a>
        ) : (
          <span class="text-slate-300">{crumb.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb-nav {
    padding: 0.75rem 0;
  }
</style>
