/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# HTML pages — short cache, always revalidate
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Root HTML
/
  Cache-Control: public, max-age=3600, must-revalidate

# SEO landing pages (generated, change rarely)
/upsc-notes/
  Cache-Control: public, max-age=86400

/jee-notes/
  Cache-Control: public, max-age=86400

/neet-notes/
  Cache-Control: public, max-age=86400

/ssc-notes/
  Cache-Control: public, max-age=86400

/banking-notes/
  Cache-Control: public, max-age=86400

/gate-notes/
  Cache-Control: public, max-age=86400

/class-12-notes/
  Cache-Control: public, max-age=86400

/class-10-notes/
  Cache-Control: public, max-age=86400

# CSS & JS — long cache with content hash
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# JSON data — medium cache
/data/resources.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

/data/categories.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

/data/clusters.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

/data/keywords.json
  Cache-Control: public, max-age=604800
  Content-Type: application/json; charset=utf-8

/data/blog-index.json
  Cache-Control: public, max-age=3600
  Content-Type: application/json; charset=utf-8

# SVG assets — long cache
/assets/*
  Cache-Control: public, max-age=2592000

# Fonts — very long cache
*.woff2
  Cache-Control: public, max-age=31536000, immutable

*.woff
  Cache-Control: public, max-age=31536000, immutable

# Images
*.svg
  Cache-Control: public, max-age=2592000
  Content-Type: image/svg+xml

*.png
  Cache-Control: public, max-age=2592000

*.jpg
  Cache-Control: public, max-age=2592000

*.webp
  Cache-Control: public, max-age=2592000

# Sitemap and robots — short cache for fresh indexing
/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml; charset=utf-8

/robots.txt
  Cache-Control: public, max-age=86400

# Blog posts — medium cache
/blog/*
  Cache-Control: public, max-age=43200

# Tool pages — short cache (interactive)
/tools/*
  Cache-Control: public, max-age=3600
